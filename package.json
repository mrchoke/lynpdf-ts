{
  "name": "lynpdf",
  "version": "2.1.1",
  "description": "LynPDF Creator — Convert HTML/CSS to PDF with Thai language support, color emoji, and flexbox layout",
  "module": "./dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "lynpdf": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "fonts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts src/cli.ts --outdir dist --target node --format esm && tsc --project tsconfig.build.json",
    "dev": "bun run run-examples.ts",
    "cli": "bun run src/cli.ts",
    "examples": "bun run tests/run-examples.ts",
    "color-diagnostic": "bun run tests/color-diagnostic.ts",
    "color-test": "bun run tests/color-test.ts",
    "test": "bun test tests/unit",
    "test:visual": "bun run tests/run-tests.ts",
    "test:all": "bun test tests/unit && bun run tests/run-tests.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "pdf",
    "html-to-pdf",
    "css-to-pdf",
    "pdf-generator",
    "thai",
    "thai-pdf",
    "emoji",
    "twemoji",
    "flexbox",
    "yoga-layout",
    "pdfkit",
    "typescript"
  ],
  "author": "Supphachoke Suntiwichaya <mrchoke@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrchoke/lynpdf-ts.git"
  },
  "bugs": {
    "url": "https://github.com/mrchoke/lynpdf-ts/issues"
  },
  "homepage": "https://github.com/mrchoke/lynpdf-ts#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/bun": "^1.3.10",
    "@types/css-tree": "^2.3.11",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "^4.0.0",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/node": "^25.5.0",
    "@types/parse5": "^7.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/svg-to-pdfkit": "^0.1.4",
    "@types/yoga-layout": "^3.1.0",
    "pdf-lib": "^1.17.1"
  },
  "dependencies": {
    "@twemoji/parser": "^17.0.1",
    "css-tree": "^3.2.1",
    "fontkit": "^2.0.4",
    "harfbuzzjs": "^0.10.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "parse5": "^8.0.0",
    "pdfkit": "^0.18.0",
    "svg-to-pdfkit": "^0.1.8",
    "yoga-layout": "^3.2.1"
  }
}